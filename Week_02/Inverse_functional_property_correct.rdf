<?xml version="1.0"?>
<rdf:RDF
    xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
    xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
    xmlns:owl="http://www.w3.org/2002/07/owl#"
    xmlns:uni="http://example.org/university#"
    xml:base="http://example.org/university">

<owl:Ontology rdf:about="http://example.org/university"/>

<!-- Classes -->
<owl:Class rdf:about="http://example.org/university#Student"/>
<owl:Class rdf:about="http://example.org/university#StudentNumber"/>

<!-- Inverse functional property -->
<owl:ObjectProperty rdf:about="http://example.org/university#hasStudentNumber">
    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#InverseFunctionalProperty"/>
    <rdfs:domain rdf:resource="http://example.org/university#Student"/>
    <rdfs:range rdf:resource="http://example.org/university#StudentNumber"/>
</owl:ObjectProperty>

<!-- Individuals -->

<owl:NamedIndividual rdf:about="http://example.org/university#Marius">
    <rdf:type rdf:resource="http://example.org/university#Student"/>
    <uni:hasStudentNumber rdf:resource="http://example.org/university#SN101"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="http://example.org/university#Andrei">
    <rdf:type rdf:resource="http://example.org/university#Student"/>
    <uni:hasStudentNumber rdf:resource="http://example.org/university#SN101"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="http://example.org/university#SN101">
    <rdf:type rdf:resource="http://example.org/university#StudentNumber"/>
</owl:NamedIndividual>

<!-- Explicitly say students are different -->
<owl:AllDifferent>
    <owl:distinctMembers rdf:parseType="Collection">
        <rdf:Description rdf:about="http://example.org/university#Marius"/>
        <rdf:Description rdf:about="http://example.org/university#Andrei"/>
    </owl:distinctMembers>
</owl:AllDifferent>

</rdf:RDF>