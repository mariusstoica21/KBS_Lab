<?xml version="1.0"?>
<rdf:RDF
 xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
 xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#"
 xmlns:owl="http://www.w3.org/2002/07/owl#"
 xmlns:uni="http://example.org/university#"
 xml:base="http://example.org/university">

<owl:Ontology rdf:about="http://example.org/university"/>

<!-- Class -->

<owl:Class rdf:about="http://example.org/university#Researcher"/>

<!-- Reflexive property -->

<owl:ObjectProperty rdf:about="http://example.org/university#sameResearchGroupAs">

    <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ReflexiveProperty"/>

    <rdfs:domain rdf:resource="http://example.org/university#Researcher"/>

    <rdfs:range rdf:resource="http://example.org/university#Researcher"/>

</owl:ObjectProperty>

<!-- Individuals -->

<owl:NamedIndividual rdf:about="http://example.org/university#Marius">
    <rdf:type rdf:resource="http://example.org/university#Researcher"/>
</owl:NamedIndividual>

<owl:NamedIndividual rdf:about="http://example.org/university#Andrei">
    <rdf:type rdf:resource="http://example.org/university#Researcher"/>
</owl:NamedIndividual>

</rdf:RDF>