<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/university#"
     xml:base="http://example.org/university"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">

    <owl:Ontology rdf:about="http://example.org/university"/>

    <!-- Classes -->

    <owl:Class rdf:about="#Student"/>
    <owl:Class rdf:about="#Teacher"/>

    <!-- Object property: hasTeacher -->

    <owl:ObjectProperty rdf:about="#hasTeacher">
        <rdfs:domain rdf:resource="#Student"/>
        <rdfs:range rdf:resource="#Teacher"/>
        <owl:inverseOf rdf:resource="#teaches"/>
    </owl:ObjectProperty>

    <!-- Object property: teaches -->

    <owl:ObjectProperty rdf:about="#teaches">
        <rdfs:domain rdf:resource="#Teacher"/>
        <rdfs:range rdf:resource="#Student"/>
    </owl:ObjectProperty>

    <!-- Individuals -->

    <owl:NamedIndividual rdf:about="#Marius">
        <rdf:type rdf:resource="#Student"/>
        <hasTeacher rdf:resource="#AdrianGroza"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#AdrianGroza">
        <rdf:type rdf:resource="#Teacher"/>
    </owl:NamedIndividual>

</rdf:RDF>