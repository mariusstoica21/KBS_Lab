<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/university#"
     xml:base="http://example.org/university"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">

    <owl:Ontology rdf:about="http://example.org/university"/>

    <!-- Classes -->
    <owl:Class rdf:about="#Group"/>
    <owl:Class rdf:about="#Teacher"/>

    <!-- Object Property -->
    <owl:ObjectProperty rdf:about="#hasCoordinator">
        <rdfs:domain rdf:resource="#Group"/>
        <rdfs:range rdf:resource="#Teacher"/>
    </owl:ObjectProperty>

    <!-- Axiom: a Group has at most 1 coordinator -->
    <owl:Class rdf:about="#Group">
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="#hasCoordinator"/>
                <owl:maxQualifiedCardinality rdf:datatype="http://www.w3.org/2001/XMLSchema#nonNegativeInteger">1</owl:maxQualifiedCardinality>
                <owl:onClass rdf:resource="#Teacher"/>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>

    <!-- Individuals -->
    <owl:NamedIndividual rdf:about="#Group1">
        <rdf:type rdf:resource="#Group"/>
        <hasCoordinator rdf:resource="#AdrianGroza"/>
        <hasCoordinator rdf:resource="#MihaiPop"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#AdrianGroza">
        <rdf:type rdf:resource="#Teacher"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="#MihaiPop">
        <rdf:type rdf:resource="#Teacher"/>
    </owl:NamedIndividual>

    <!-- Explicitly state they are different -->
    <owl:AllDifferent>
        <owl:distinctMembers rdf:parseType="Collection">
            <rdf:Description rdf:about="#AdrianGroza"/>
            <rdf:Description rdf:about="#MihaiPop"/>
        </owl:distinctMembers>
    </owl:AllDifferent>

</rdf:RDF>