<?xml version="1.0"?>
<rdf:RDF xmlns="http://example.org/university#"
     xml:base="http://example.org/university"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">

    <owl:Ontology rdf:about="http://example.org/university"/>

    <!-- Class -->
    <owl:Class rdf:about="http://example.org/university#Student"/>

    <!-- Object Property -->
    <owl:ObjectProperty rdf:about="http://example.org/university#isInSameResearchGroupAs">
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#SymmetricProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#TransitiveProperty"/>
        <rdf:type rdf:resource="http://www.w3.org/2002/07/owl#ReflexiveProperty"/>
        <rdfs:domain rdf:resource="http://example.org/university#Student"/>
        <rdfs:range rdf:resource="http://example.org/university#Student"/>
    </owl:ObjectProperty>

    <!-- Individuals -->
    <owl:NamedIndividual rdf:about="http://example.org/university#Marius">
        <rdf:type rdf:resource="http://example.org/university#Student"/>
        <isInSameResearchGroupAs rdf:resource="http://example.org/university#Catalin"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/university#Catalin">
        <rdf:type rdf:resource="http://example.org/university#Student"/>
        <isInSameResearchGroupAs rdf:resource="http://example.org/university#Andrei"/>
    </owl:NamedIndividual>

    <owl:NamedIndividual rdf:about="http://example.org/university#Andrei">
        <rdf:type rdf:resource="http://example.org/university#Student"/>
    </owl:NamedIndividual>

</rdf:RDF>